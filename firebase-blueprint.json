{
  "entities": {
    "Request": {
      "title": "Purchase Request",
      "description": "A request from a buyer for specific goods",
      "type": "object",
      "properties": {
        "buyerId": { "type": "string", "description": "UID of the buyer" },
        "buyerName": { "type": "string", "description": "Name of the buyer/restaurant" },
        "productName": { "type": "string", "description": "Name of the product requested" },
        "quantity": { "type": "string", "description": "Amount requested (e.g. 10 cartons)" },
        "unit": { "type": "string", "description": "Unit of measurement (e.g. cartons)" },
        "category": { "type": "string", "description": "Category of the goods" },
        "status": { "type": "string", "enum": ["active", "accepted", "preparing", "shipped", "delivered", "cancelled", "partially_accepted"] },
        "requestType": { "type": "string", "enum": ["standard", "bulk"] },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productName": { "type": "string" },
              "quantity": { "type": "number" },
              "unit": { "type": "string" },
              "acceptedBidId": { "type": "string" },
              "supplierId": { "type": "string" },
              "supplierName": { "type": "string" },
              "price": { "type": "number" },
              "status": { "type": "string", "enum": ["pending", "accepted"] }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "deadline": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "address": { "type": "string", "description": "Detailed delivery address" },
        "phone": { "type": "string", "description": "Contact phone number" },
        "totalAmount": { "type": "number", "description": "Total calculated price" },
        "offerId": { "type": "string", "description": "Reference to the original offer if any" },
        "coordinates": { 
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "notes": { "type": "string" },
        "acceptedBidId": { "type": "string" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "price": { "type": "number" },
        "deliveryTime": { "type": "number" },
        "bidsCount": { "type": "number" }
      },
      "required": ["buyerId", "productName", "status", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notifications for events like bid acceptance",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the notification recipient" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["bid_accepted", "new_bid", "system"] },
        "read": { "type": "boolean" },
        "broadcastId": { "type": "string", "description": "ID of the parent broadcast if applicable" },
        "createdAt": { "type": "string", "format": "date-time" },
        "link": { "type": "string", "description": "Target path for navigation" }
      },
      "required": ["userId", "title", "message", "type", "read", "createdAt"]
    },
    "Bid": {
      "title": "Supplier Bid",
      "description": "A price offer from a supplier for a specific request",
      "type": "object",
      "properties": {
        "requestId": { "type": "string", "description": "ID of the request being bid on" },
        "supplierId": { "type": "string", "description": "UID of the supplier" },
        "supplierName": { "type": "string", "description": "Name of the supplier" },
        "price": { "type": "number", "description": "Total price offered" },
        "deliveryTime": { "type": "number", "description": "Delivery time in minutes" },
        "notes": { "type": "string" },
        "coordinates": { 
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"] }
      },
      "required": ["requestId", "supplierId", "price", "deliveryTime", "status", "createdAt"]
    },
    "Offer": {
      "title": "Promotional Offer",
      "description": "A promotional discount offer created by a supplier",
      "type": "object",
      "properties": {
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "title": { "type": "string" },
        "originalPrice": { "type": "number" },
        "offerPrice": { "type": "number" },
        "discount": { "type": "string" },
        "image": { "type": "string" },
        "category": { "type": "string", "description": "Category ID or name for fallback icon" },
        "quantity": { "type": "number", "description": "Quantity available or per unit" },
        "unit": { "type": "string", "description": "Unit of measurement (kg, box, carton, etc.)" },
        "status": { "type": "string", "enum": ["active", "expired"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "views": { "type": "number" },
        "orders": { "type": "number" },
        "sortOrder": { "type": "number", "description": "Admin defined display order" },
        "showInGuestMarketplace": { "type": "boolean", "description": "Whether to show this offer to non-authenticated users" }
      },
      "required": ["supplierId", "title", "originalPrice", "offerPrice"]
    },
    "Product": {
      "title": "Supplier Product",
      "description": "A catalog item offered by a supplier",
      "type": "object",
      "properties": {
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "unit": { "type": "string" },
        "category": { "type": "string" },
        "image": { "type": "string" },
        "available": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["supplierId", "name", "price", "category"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "Extended profile information for buyers or suppliers",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "businessName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "role": { "type": "string", "enum": ["buyer", "supplier"] },
        "avatarUrl": { "type": "string" },
        "fcmTokens": { "type": "array", "items": { "type": "string" }, "description": "Device tokens for push notifications" },
        "notificationsEnabled": { "type": "boolean" },
        "subscriptionStatus": { "type": "string", "enum": ["active", "expired", "not_subscribed"] },
        "subscriptionStart": { "type": "string", "format": "date-time" },
        "subscriptionExpiry": { "type": "string", "format": "date-time" },
        "isTrial": { "type": "boolean", "description": "Whether the user is currently in a trial period" },
        "isApproved": { "type": "boolean", "description": "Whether the admin has approved this account" },
        "isTrusted": { "type": "boolean", "description": "Whether the supplier is featured on homepage" },
        "sortOrder": { "type": "number", "description": "Admin defined display order" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "PaymentMethod": {
      "title": "Payment Method",
      "description": "Saved payment card information",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "cardHolder": { "type": "string" },
        "cardNumber": { "type": "string", "description": "Obfuscated card number" },
        "expiryDate": { "type": "string" },
        "type": { "type": "string", "enum": ["visa", "mastercard"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "cardHolder", "cardNumber", "expiryDate"]
    },
    "AppSetting": {
      "title": "Application Setting",
      "description": "Global application configuration",
      "type": "object",
      "properties": {
        "commissionRate": { "type": "number", "description": "Platform commission percentage (0-100)" },
        "buyerSubPrice": { "type": "number", "description": "Price for 6-month buyer subscription" },
        "supplierSubPrice": { "type": "number", "description": "Price for 6-month supplier subscription" },
        "trialDays": { "type": "number", "description": "Default duration for trial period in days" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["commissionRate", "buyerSubPrice", "supplierSubPrice"]
    },
    "Admin": {
      "title": "Platform Admin",
      "description": "User with full administrative access",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Message": {
      "title": "Chat Message",
      "description": "A message sent in the real-time chat between buyer and supplier",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["text", "senderId", "createdAt"]
    },
    "SubscriptionPayment": {
      "title": "Subscription Payment",
      "description": "Log of a subscription purchase",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userRole": { "type": "string" },
        "userName": { "type": "string" },
        "businessName": { "type": "string" },
        "amount": { "type": "number" },
        "durationMonths": { "type": "number", "default": 6 },
        "paymentDate": { "type": "string", "format": "date-time" },
        "expiryDate": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "paymentDate", "expiryDate"]
    },
    "Broadcast": {
      "title": "System Broadcast",
      "description": "A global message sent by admin to users",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "target": { "type": "string", "enum": ["all", "buyer", "supplier"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "message", "target", "createdAt"]
    },
    "PageStat": {
      "title": "Page Analytics",
      "description": "Counter for page visits and clicks",
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "visits": { "type": "number" },
        "clicks": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "OfferStat": {
      "title": "Offer Analytics",
      "description": "Interaction stats for a specific offer",
      "type": "object",
      "properties": {
        "offerId": { "type": "string" },
        "offerTitle": { "type": "string" },
        "supplierName": { "type": "string" },
        "views": { "type": "number" },
        "clicks": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "Platform administrators"
    },
    "/settings/{settingId}": {
      "schema": "AppSetting",
      "description": "Global app settings"
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Extended user profile data"
    },
    "/users/{userId}/payment_methods/{methodId}": {
      "schema": "PaymentMethod",
      "description": "Saved payment methods for the user"
    },
    "/requests/{requestId}": {
      "schema": "Request",
      "description": "All purchase requests"
    },
    "/requests/{requestId}/bids/{bidId}": {
      "schema": "Bid",
      "description": "Bids for a specific request"
    },
    "/requests/{requestId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages for a request"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Supplier catalog products"
    },
    "/offers/{offerId}": {
      "schema": "Offer",
      "description": "Promotional offers created by suppliers"
    },
    "/system_broadcasts/{broadcastId}": {
      "schema": "Broadcast",
      "description": "History of admin broadcast messages"
    },
    "/subscription_payments/{paymentId}": {
      "schema": "SubscriptionPayment",
      "description": "History of all subscription payments"
    },
    "/page_stats/{pathId}": {
      "schema": "PageStat",
      "description": "Global page visit counters"
    },
    "/offer_stats/{offerId}": {
      "schema": "OfferStat",
      "description": "Offer engagement counters"
    }
  }
}
