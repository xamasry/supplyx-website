rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // -- GLOBALS --
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      // Hardened: In production, use request.auth.token.email_verified == true
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'masriboro@gmail.com'
      );
    }

    // -- VALIDATION HELPERS --

    function isValidRequest(data) {
      return data.keys().hasAll(['buyerId', 'productName', 'quantity', 'status', 'createdAt'])
        && data.buyerId == request.auth.uid
        && data.productName is string && data.productName.size() <= 200
        && data.quantity is string && data.quantity.size() <= 100
        && data.status in ['active', 'accepted', 'preparing', 'shipped', 'delivered', 'cancelled']
        && (data.price == null || data.price is number)
        && (data.totalAmount == null || data.totalAmount is number);
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'read', 'createdAt'])
        && data.userId is string
        && data.title is string && data.title.size() <= 100
        && data.message is string && data.message.size() <= 500
        && data.read is bool;
    }

    function isValidOffer(data) {
      return data.keys().hasAll(['supplierId', 'title', 'originalPrice', 'offerPrice'])
        && data.supplierId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.originalPrice is number
        && data.offerPrice is number;
    }

    // -- COLLECTIONS --

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId) || isAdmin();
      
      match /payment_methods/{methodId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /offers/{offerId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (
        existing().supplierId == request.auth.uid ||
        incoming().diff(existing()).affectedKeys().hasOnly(['orders', 'updatedAt'])
      ));
      allow delete: if isAdmin() || (isSignedIn() && existing().supplierId == request.auth.uid);
    }

    match /requests/{requestId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      
      allow create: if isSignedIn() && 
        (incoming().buyerId == request.auth.uid || incoming().userId == request.auth.uid || isAdmin());
      
      allow update: if isSignedIn();
      allow delete: if isAdmin();

      match /bids/{bidId} {
        allow list, get, write: if isSignedIn();
      }

      match /messages/{messageId} {
        allow list, get, create: if isSignedIn();
      }
    }

    match /notifications/{notificationId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn(); // Allow creating notifications for others (e.g. bid accepted)
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
