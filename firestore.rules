rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // -- GLOBALS --
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isVerified() {
      // Relaxing email verification requirement for development
      return isSignedIn();
    }

    function isValidRequest(data) {
      // Relaxed validation for updates
      return data.status in ['active', 'accepted', 'preparing', 'shipped', 'delivered', 'cancelled']
        && data.productName is string && data.productName.size() <= 200;
    }

    function isValidBid(data) {
      // Relaxed validation for updates
      return data.status in ['pending', 'accepted', 'rejected']
        && data.price is number && data.price >= 0;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isRequestOwner(requestId) {
      let r = get(/databases/$(database)/documents/requests/$(requestId)).data;
      return r.buyerId == request.auth.uid || r.userId == request.auth.uid;
    }

    // -- COLLECTIONS --

    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
    }

    match /offers/{offerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /requests/{requestId} {
      allow read: if isSignedIn();
      
      allow create: if isSignedIn() && 
        isValidId(requestId) && 
        (incoming().buyerId == request.auth.uid || incoming().userId == request.auth.uid);
      
      allow update: if (
        isSignedIn() && (
        isAdmin() ||
        
        // Action: Buyer/Owner
        ( (existing().buyerId == request.auth.uid || existing().userId == request.auth.uid) && 
          incoming().diff(existing()).affectedKeys().hasAny(['status', 'acceptedBidId', 'supplierId', 'supplierName', 'price', 'deliveryTime', 'buyerConfirmPhone', 'buyerConfirmLocation', 'updatedAt', 'productName', 'quantity', 'category', 'description', 'location', 'coordinates'])) ||
        
        // Action: Assigned Supplier
        ( (existing().supplierId == request.auth.uid) && 
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||

        // Action: Public (counter update)
        ( incoming().diff(existing()).affectedKeys().hasOnly(['bidsCount', 'updatedAt']))
        )
      );

      allow delete: if isAdmin() || ( (existing().buyerId == request.auth.uid || existing().userId == request.auth.uid) && existing().status == 'active');

      match /bids/{bidId} {
        allow read: if isSignedIn();
        
        allow create: if isSignedIn() &&
          isValidId(bidId) &&
          incoming().supplierId == request.auth.uid;
        
        allow update: if (
          isSignedIn() && (
          isAdmin() ||
          
          // Action: Supplier
          (existing().supplierId == request.auth.uid &&
           incoming().diff(existing()).affectedKeys().hasOnly(['status', 'price', 'deliveryTime', 'notes', 'updatedAt', 'coordinates'])) ||
          
          // Action: Buyer/Owner of Request
          (isRequestOwner(requestId) &&
           incoming().diff(existing()).affectedKeys().hasAny(['status', 'updatedAt']))
          )
        );

        allow delete: if isAdmin() || (existing().supplierId == request.auth.uid);
      }

      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          existing().buyerId == request.auth.uid || 
          existing().userId == request.auth.uid || 
          existing().supplierId == request.auth.uid ||
          get(/databases/$(database)/documents/requests/$(requestId)).data.buyerId == request.auth.uid ||
          get(/databases/$(database)/documents/requests/$(requestId)).data.supplierId == request.auth.uid
        );
        allow create: if isSignedIn() && (
          get(/databases/$(database)/documents/requests/$(requestId)).data.buyerId == request.auth.uid ||
          get(/databases/$(database)/documents/requests/$(requestId)).data.supplierId == request.auth.uid
        ) && incoming().senderId == request.auth.uid;
      }
    }
  }
}
