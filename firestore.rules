rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // -- GLOBALS --
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      // Hardened: In production, use request.auth.token.email_verified == true
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSuperAdmin() {
      return isSignedIn() && 
        (
          (request.auth.token.keys().contains('email') && request.auth.token.email.lower() == 'masriboro@gmail.com') ||
          request.auth.uid == 'NiDR1AAMDuTGXqbYXfIs4TTijRk2'
        );
    }

    function isAdmin() {
      return isSignedIn() && (
        isSuperAdmin() ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isSupplier() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'supplier';
    }

    // -- VALIDATION HELPERS --

    function isValidRequest(data) {
      return data.keys().hasAll(['buyerId', 'productName', 'quantity', 'status', 'createdAt'])
        && data.buyerId == request.auth.uid
        && data.productName is string && data.productName.size() <= 200
        && data.quantity is string && data.quantity.size() <= 100
        && data.status in ['active', 'accepted', 'preparing', 'shipped', 'delivered', 'cancelled', 'rejected', 'pending']
        && (data.price == null || data.price is number)
        && (data.totalAmount == null || data.totalAmount is number);
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'read', 'createdAt'])
        && data.userId is string
        && data.title is string && data.title.size() <= 100
        && data.message is string && data.message.size() <= 1500
        && data.read is bool
        && (data.broadcastId == null || data.broadcastId is string);
    }

    function isValidBroadcast(data) {
      return data.keys().hasAll(['title', 'message', 'target', 'createdAt'])
        && data.title is string && data.title.size() <= 100
        && data.message is string && data.message.size() <= 1500
        && data.target in ['all', 'buyer', 'supplier'];
    }

    function isValidOffer(data) {
      return data.keys().hasAll(['supplierId', 'title', 'originalPrice', 'offerPrice'])
        && data.supplierId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.originalPrice is number
        && data.offerPrice is number;
    }

    // -- COLLECTIONS --

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isSuperAdmin();
    }

    match /users/{userId} {
      allow list: if isAdmin() || (isSignedIn() && resource.data.role == 'supplier');
      allow get: if isSignedIn() && (isOwner(userId) || isAdmin() || resource.data.role == 'supplier');
      allow create, update, delete: if isOwner(userId) || isAdmin();
      
      match /payment_methods/{methodId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && (isSupplier() || isAdmin()) && isValidId(productId) && isValidProduct(incoming());
      allow update: if isSignedIn() && (isAdmin() || (isSupplier() && resource.data.supplierId == request.auth.uid)) && isValidProduct(incoming());
      allow delete: if isSignedIn() && (isAdmin() || (isSupplier() && resource.data.supplierId == request.auth.uid));
    }

    // --- Validation Helpers ---

    function isValidProduct(data) {
      return data.keys().hasAll(['supplierId', 'supplierName', 'name', 'price', 'category']) &&
             (isAdmin() || data.supplierId == request.auth.uid) &&
             data.name is string && data.name.size() <= 200 &&
             data.price is number && data.price >= 0 &&
             data.category is string;
    }

    match /offers/{offerId} {
      allow read: if true;
      allow create: if isSignedIn() && (isSupplier() || isAdmin()) && isValidId(offerId);
      allow update: if isAdmin() || (isSignedIn() && (
        (isSupplier() && existing().supplierId == request.auth.uid) ||
        incoming().diff(existing()).affectedKeys().hasOnly(['orders', 'updatedAt'])
      ));
      allow delete: if isAdmin() || (isSignedIn() && isSupplier() && existing().supplierId == request.auth.uid);
    }

    match /{path=**}/bids/{bidId} {
      allow list: if isSignedIn() && (
        resource.data.supplierId == request.auth.uid || 
        isAdmin() ||
        (resource.data.keys().contains('requestId') && get(/databases/$(database)/documents/requests/$(resource.data.requestId)).data.buyerId == request.auth.uid)
      );
      allow get: if isSignedIn();
    }

    match /requests/{requestId}/bids/{bidId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(bidId) && incoming().supplierId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.supplierId == request.auth.uid || 
        isAdmin() ||
        (get(/databases/$(database)/documents/requests/$(requestId)).data.buyerId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
      );
      allow delete: if isSignedIn() && (resource.data.supplierId == request.auth.uid || isAdmin());
    }

    match /requests/{requestId} {
      allow list: if resource.data.status == 'active' || isAdmin() || (isSignedIn() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.supplierId == request.auth.uid
      ));
      allow get: if isAdmin() || isSignedIn();
      allow create: if isSignedIn() && isValidId(requestId) && incoming().buyerId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.supplierId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow list, get: if isSignedIn();
        allow create: if isSignedIn() && isValidId(messageId);
      }
    }

    match /orders/{orderId} {
      allow list: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.supplierId == request.auth.uid
      );
      allow get: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.supplierId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isSignedIn() && isValidId(orderId);
      allow update: if isSignedIn() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.supplierId == request.auth.uid ||
        isAdmin()
      );
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow list, get: if isSignedIn();
        allow create: if isSignedIn() && isValidId(messageId);
      }
    }

    match /notifications/{notificationId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn(); 
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']));
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /system_broadcasts/{broadcastId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /system_logs/{logId} {
      allow create: if true; // Allow anyone to log (including public errors)
      allow read: if isAdmin();
    }

    match /system_alerts/{alertId} {
      allow create: if true;
      allow read, update: if isAdmin();
    }

    match /exclusive_offers/{offerId} {
      allow read: if true;
      allow create: if isSignedIn() && isSupplier() && isValidId(offerId);
      allow update: if isSignedIn() && (isAdmin() || (resource.data.supplierId == request.auth.uid));
      allow delete: if isAdmin() || (isSignedIn() && resource.data.supplierId == request.auth.uid);
    }

    match /subscription_requests/{requestId} {
      allow list, get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && isValidId(requestId) && incoming().userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /subscription_payments/{paymentId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /page_stats/{pathId} {
      allow read: if true;
      allow create, update: if true; // Publicly trackable
    }

    match /offer_stats/{offerId} {
      allow read: if true;
      allow create, update: if true; // Publicly trackable
    }
  }
}
