rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // -- GLOBALS --
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      // Hardened: In production, use request.auth.token.email_verified == true
      return isSignedIn();
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isSuperAdmin() {
      return isSignedIn() && 
        request.auth.token.keys().contains('email') && 
        (
          request.auth.token.email.matches('(?i)masriboro@gmail\\.com') ||
          request.auth.uid == 'NiDR1AAMDuTGXqbYXfIs4TTijRk2'
        );
    }

    function isAdmin() {
      return isSignedIn() && (
        isSuperAdmin() ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    // -- VALIDATION HELPERS --

    function isValidRequest(data) {
      return data.keys().hasAll(['buyerId', 'productName', 'quantity', 'status', 'createdAt'])
        && data.buyerId == request.auth.uid
        && data.productName is string && data.productName.size() <= 200
        && data.quantity is string && data.quantity.size() <= 100
        && data.status in ['active', 'accepted', 'preparing', 'shipped', 'delivered', 'cancelled']
        && (data.price == null || data.price is number)
        && (data.totalAmount == null || data.totalAmount is number);
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'read', 'createdAt'])
        && data.userId is string
        && data.title is string && data.title.size() <= 100
        && data.message is string && data.message.size() <= 1500
        && data.read is bool
        && (data.broadcastId == null || data.broadcastId is string);
    }

    function isValidBroadcast(data) {
      return data.keys().hasAll(['title', 'message', 'target', 'createdAt'])
        && data.title is string && data.title.size() <= 100
        && data.message is string && data.message.size() <= 1500
        && data.target in ['all', 'buyer', 'supplier'];
    }

    function isValidOffer(data) {
      return data.keys().hasAll(['supplierId', 'title', 'originalPrice', 'offerPrice'])
        && data.supplierId == request.auth.uid
        && data.title is string && data.title.size() <= 200
        && data.originalPrice is number
        && data.offerPrice is number;
    }

    // -- COLLECTIONS --

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isSuperAdmin();
    }

    match /users/{userId} {
      allow list: if isAdmin();
      allow get: if isSignedIn();
      allow create, update: if isOwner(userId) || isAdmin();
      
      match /payment_methods/{methodId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }

    match /offers/{offerId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && (
        existing().supplierId == request.auth.uid ||
        incoming().diff(existing()).affectedKeys().hasOnly(['orders', 'updatedAt'])
      ));
      allow delete: if isAdmin() || (isSignedIn() && existing().supplierId == request.auth.uid);
    }

    match /requests/{requestId}/bids/{bidId} {
      allow read, write: if isSignedIn();
    }

    match /requests/{requestId} {
      allow list: if isAdmin() || (isSignedIn() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.supplierId == request.auth.uid || 
        resource.data.status == 'active'
      ));
      allow get: if isAdmin() || isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow list, get, create: if isSignedIn();
      }
    }

    match /orders/{orderId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn();
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow list, get, create: if isSignedIn();
      }
    }

    match /notifications/{notificationId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn(); 
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['read']));
      allow delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    match /system_broadcasts/{broadcastId} {
      allow read: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
  }
}
