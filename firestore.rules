rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // 1. Mandatory Size Enforcements & Type Safety
    function isValidRequest(data) {
      return data.buyerId is string
        && data.status in ['active', 'accepted', 'preparing', 'shipped', 'delivered', 'cancelled']
        && (data.createdAt == null || data.createdAt == request.time || (resource != null && data.createdAt == resource.data.createdAt))
        && (data.updatedAt == null || data.updatedAt == request.time || (resource != null && data.updatedAt == resource.data.updatedAt))
        && data.productName is string && data.productName.size() <= 200;
    }

    function isValidBid(data) {
      return data.supplierId is string
        && data.status in ['pending', 'accepted', 'rejected']
        && (data.createdAt == null || data.createdAt == request.time || (resource != null && data.createdAt == resource.data.createdAt))
        && (data.updatedAt == null || data.updatedAt == request.time || (resource != null && data.updatedAt == resource.data.updatedAt))
        && data.price is number && data.price >= 0
        && (data.deliveryTime == null || data.deliveryTime is number)
        && (data.supplierName == null || data.supplierName is string);
    }

    function isValidNotification(data) {
      return data.userId is string
        && data.type in ['bid_accepted', 'new_bid', 'system']
        && data.read is bool
        && (data.createdAt == null || data.createdAt == request.time || (resource != null && data.createdAt == resource.data.createdAt));
    }

    function isValidOffer(data) {
      return data.supplierId is string
        && data.status in ['active', 'expired']
        && (data.createdAt == null || data.createdAt == request.time || (resource != null && data.createdAt == resource.data.createdAt))
        && (data.updatedAt == null || data.updatedAt == request.time || (resource != null && data.updatedAt == request.time))
        && data.originalPrice is number && data.offerPrice is number
        && data.title is string && data.title.size() <= 200
        && data.discount is string && data.discount.size() <= 10
        && (data.image == null || data.image is string)
        && (data.supplierName == null || data.supplierName is string)
        && (data.views == null || data.views is number)
        && (data.orders == null || data.orders is number);
    }

    function isValidUserProfile(data) {
      return (data.role == null || data.role in ['buyer', 'supplier'])
        && (data.updatedAt == null || data.updatedAt == request.time);
    }

    // Phase 4: Match Blocks
    match /users/{userId} {
      allow get: if isSignedIn();
      allow create, update: if isOwner(userId) && isValidUserProfile(incoming());
      
      match /payment_methods/{methodId} {
        allow get, list, create, update, delete: if isOwner(userId);
      }
    }

    match /offers/{offerId} {
      allow list, get: if isSignedIn();
      allow create: if isSignedIn() && incoming().supplierId == request.auth.uid && isValidOffer(incoming());
      allow update: if isSignedIn() && (
        (resource.data.supplierId == request.auth.uid && isValidOffer(incoming())
         && (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'originalPrice', 'offerPrice', 'discount', 'status', 'updatedAt', 'image']))) ||
        (isValidOffer(incoming()) && incoming().diff(existing()).affectedKeys().hasOnly(['orders', 'updatedAt', 'views']))
      );
      allow delete: if isSignedIn() && resource.data.supplierId == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow list: if isSignedIn() && resource.data.get('userId', '') == request.auth.uid;
      allow get: if isSignedIn() && resource.data.get('userId', '') == request.auth.uid;
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if isSignedIn() && resource.data.get('userId', '') == request.auth.uid 
                     && incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && resource.data.get('userId', '') == request.auth.uid;
    }
    match /requests/{requestId} {
      // 8. Secure List Queries (Query Enforcer)
      allow list: if isSignedIn() && (
        resource.data.status == 'active' || 
        resource.data.buyerId == request.auth.uid ||
        resource.data.supplierId == request.auth.uid
      );
      allow get: if isSignedIn();
      
      allow create: if isSignedIn() && incoming().buyerId == request.auth.uid && isValidRequest(incoming());

      allow update: if isSignedIn() && (
        // Action: Buyer accepts a bid
        (existing().buyerId == request.auth.uid && 
         incoming().status == 'accepted' && 
         isValidRequest(incoming()) &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'acceptedBidId', 'supplierId', 'supplierName', 'price', 'deliveryTime', 'updatedAt'])) ||
        
        // Action: Supplier updates status
        (existing().supplierId == request.auth.uid && 
         incoming().status in ['preparing', 'shipped', 'delivered'] &&
         isValidRequest(incoming()) &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'supplierId', 'supplierName', 'buyerId', 'productName', 'quantity', 'category', 'createdAt'])) ||
         
        // Action: Buyer cancels
        (existing().buyerId == request.auth.uid && 
         incoming().status == 'cancelled' &&
         isValidRequest(incoming()) &&
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
      );

      match /bids/{bidId} {
        allow list: if isSignedIn() && (
          get(/databases/$(database)/documents/requests/$(requestId)).data.buyerId == request.auth.uid || 
          resource.data.supplierId == request.auth.uid
        );
        allow get: if isSignedIn();

        allow create: if isSignedIn() && incoming().supplierId == request.auth.uid && isValidBid(incoming())
                       && get(/databases/$(database)/documents/requests/$(requestId)).data.status == 'active';

        allow update: if isSignedIn() && (
          // Action: Supplier updates their bid
          (existing().supplierId == request.auth.uid && 
           isValidBid(incoming()) &&
           incoming().status == existing().status &&
           incoming().diff(existing()).affectedKeys().hasOnly(['price', 'deliveryTime', 'notes', 'updatedAt', 'coordinates'])) ||
          
          // Action: Buyer accepts/rejects bid
          (get(/databases/$(database)/documents/requests/$(requestId)).data.buyerId == request.auth.uid &&
           isValidBid(incoming()) &&
           incoming().status in ['accepted', 'rejected'] &&
           incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']))
        );
      }
    }
  }
}
