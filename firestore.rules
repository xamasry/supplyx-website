rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // -- GLOBALS --
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isVerified() {
      // Relaxing email verification requirement for development
      return isSignedIn();
    }

    function isValidRequest(data) {
      // Relaxed validation for updates
      return data.status in ['active', 'accepted', 'preparing', 'shipped', 'delivered', 'cancelled']
        && data.productName is string && data.productName.size() <= 200;
    }

    function isValidBid(data) {
      // Relaxed validation for updates
      return data.status in ['pending', 'accepted', 'rejected']
        && data.price is number && data.price >= 0;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'masriboro@gmail.com'
      );
    }

    function isRequestOwner(requestId) {
      let r = get(/databases/$(database)/documents/requests/$(requestId)).data;
      return r.buyerId == request.auth.uid || r.userId == request.auth.uid;
    }

    function isValidPaymentMethod(data) {
      return data.keys().hasAll(['cardHolder', 'cardNumber', 'expiryDate', 'type', 'userId', 'createdAt'])
        && data.cardHolder is string && data.cardHolder.size() <= 100
        && data.cardNumber is string && data.cardNumber.size() <= 20
        && data.expiryDate is string && data.expiryDate.size() <= 10
        && data.type in ['visa', 'mastercard']
        && data.userId == request.auth.uid;
    }

    // -- COLLECTIONS --
    
    match /users {
      allow list: if isSignedIn();
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if isAdmin() || isOwner(userId);

      match /payment_methods/{methodId} {
        allow read, write: if isAdmin() || isOwner(userId);
      }
    }

    match /phone_verifications/{phone} {
      allow read: if true;
      allow write: if false;
    }

    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /offers/{offerId} {
      allow read: if true;
      allow create: if isSignedIn(); // We can add check for role if needed, but let's keep it simple
      allow update, delete: if isAdmin() || (isSignedIn() && existing().supplierId == request.auth.uid);
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /notifications {
      allow list, read, write: if isAdmin();
      allow list: if isSignedIn();
    }

    match /notifications/{notificationId} {
      allow read, write: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
    }

    match /requests {
      allow read, write: if isAdmin();
      allow list: if isSignedIn();
    }

    match /requests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.status == 'active' ||
        resource.data.buyerId == request.auth.uid || 
        resource.data.userId == request.auth.uid || 
        resource.data.supplierId == request.auth.uid ||
        isAdmin()
      );
      
      allow create: if isSignedIn() && 
        isValidId(requestId) && 
        (incoming().buyerId == request.auth.uid || incoming().userId == request.auth.uid || isAdmin());
      
      allow update: if isSignedIn() && (
        isAdmin() ||
        
        // Action: Buyer/Owner
        ( (existing().buyerId == request.auth.uid || existing().userId == request.auth.uid) && 
          incoming().diff(existing()).affectedKeys().hasAny(['status', 'acceptedBidId', 'supplierId', 'supplierName', 'price', 'deliveryTime', 'buyerConfirmPhone', 'buyerConfirmLocation', 'updatedAt', 'productName', 'quantity', 'category', 'description', 'location', 'coordinates', 'supplierPhone'])) ||
        
        // Action: Assigned Supplier
        ( (existing().supplierId == request.auth.uid) && 
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
  
        // Action: Public (counter update)
        ( incoming().diff(existing()).affectedKeys().hasOnly(['bidsCount', 'updatedAt']))
      );
      
      allow delete: if isAdmin() || ( (existing().buyerId == request.auth.uid || existing().userId == request.auth.uid) && existing().status == 'active');

      match /bids {
        allow read, write: if isAdmin();
        allow list: if isSignedIn();
      }

      match /bids/{bidId} {
        allow read: if isSignedIn() && (
          resource.data.supplierId == request.auth.uid ||
          get(/databases/$(database)/documents/requests/$(requestId)).data.buyerId == request.auth.uid ||
          get(/databases/$(database)/documents/requests/$(requestId)).data.userId == request.auth.uid ||
          isAdmin()
        );
        
        allow create: if isSignedIn() &&
          isValidId(bidId) &&
          (incoming().supplierId == request.auth.uid || isAdmin());
        
        allow update: if isSignedIn() && (
          isAdmin() ||
          
          // Action: Supplier
          (existing().supplierId == request.auth.uid &&
           incoming().diff(existing()).affectedKeys().hasOnly(['status', 'price', 'deliveryTime', 'notes', 'updatedAt', 'coordinates'])) ||
          
          // Action: Buyer/Owner of Request
          (isRequestOwner(requestId) &&
           incoming().diff(existing()).affectedKeys().hasAny(['status', 'updatedAt']))
        );
  
        allow delete: if isAdmin() || (existing().supplierId == request.auth.uid);
      }
  
      match /messages {
        allow read, write: if isAdmin();
        allow list: if isSignedIn();
      }

      match /messages/{messageId} {
        allow read: if isSignedIn() && (
          request.auth.uid in resource.data.participants || isAdmin()
        );
        allow create: if isSignedIn() && (
          request.auth.uid in incoming().participants || isAdmin()
        ) && (incoming().senderId == request.auth.uid || isAdmin());
      }
    }

  }
}
